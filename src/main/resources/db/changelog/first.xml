<?xml version="1.0" encoding="UTF-8" ?>
<databaseChangeLog
        xmlns="http://www.liquibase.org/xml/ns/dbchangelog"
        xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
        xsi:schemaLocation="http://www.liquibase.org/xml/ns/dbchangelog
        https://www.liquibase.org/xml/ns/dbchangelog/dbchangelog-4.4.xsd">
    <changeSet id="202502171735" author="Moh1to">
        <createTable tableName="apartment">
            <column name="id" type="serial">
                <constraints primaryKey="true" primaryKeyName="apartment_id_pk"/>
            </column>
            <column name="city" type="varchar(255)"/>
            <column name="street" type="varchar(255)"/>
            <column name="house" type="varchar(10)"/>
            <column name="corpus" type="varchar(10)"/>
            <column name="room_count" type="varchar(50)"/>
        </createTable>
    </changeSet>
</databaseChangeLog>



































